# walkthrough/local-notes.env.example
#
# Copy to walkthrough/local-notes.env (gitignored) and fill in the real
# values for YOUR Windows host. The 02 / 03 scripts source this file.
#
#   cp walkthrough/local-notes.env.example walkthrough/local-notes.env
#   chmod 600 walkthrough/local-notes.env
#   $EDITOR walkthrough/local-notes.env
#
# DO NOT add the filled-in copy to git — the .gitignore rule
# `walkthrough/local-*` already excludes it. Verify with `git status`
# before any commit.

# ── Windows target ─────────────────────────────────────────────
# IP or hostname the Linux side can reach.
WIN_HOST=192.168.1.10

# Local Windows username used for ssh + ACL.
WIN_USER=YourWindowsUser

# Pretty label for workspace/hosts/<label>/... bucketing. Match the
# value in your `walkthrough` profile. ASCII-only, no spaces.
WIN_LABEL=win-walkthrough

# ── wlb controller paths ───────────────────────────────────────
# SSH keypair the walkthrough uses. Generated by 02-linux-pair.sh
# if missing. Keep these out of your default ~/.ssh/ keys.
WLB_KEY=~/.ssh/wlb_walkthrough_ed25519

# Named wlb profile this walkthrough writes to. Stays separate from
# your normal default profile so you can revert easily.
WLB_PROFILE=walkthrough

# ── wlb-agent (HTTP transport) ─────────────────────────────────
# Port the agent listens on (Windows side firewall opens this).
WIN_AGENT_PORT=8443

# Token file on the Linux side. The Windows side writes the same
# token to C:\ProgramData\wlb-agent\token; you transfer the file
# (Samba / USB / scp) and chmod 600 the controller copy.
WLB_HTTP_TOKEN_FILE=~/.config/wlb/http-token-walkthrough

# CA cert if you generated a self-signed agent cert (recommended).
# Leave unset to use plain HTTP for lab testing.
WLB_HTTP_CA_BUNDLE=

# ── Optional: smoke-test target paths ──────────────────────────
# Windows path the filesync smoke test writes to. Pick somewhere
# safe and writable for WIN_USER.
WIN_STAGE_DIR=C:\Users\YourWindowsUser\wlb-stage
