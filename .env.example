# windows-llm-bridge — example environment file
#
# Copy to .env and fill in values for your setup. .env is gitignored.
# .env.local also works and takes precedence over .env.
#
# These values feed wlb.infra.config.load_active() on every invocation.

# ─── SSH target (M1) ──────────────────────────────────────────────
# The Windows host that runs OpenSSH Server. Hostname or IP.
WLB_SSH_HOST=<win-host>

# Port (default 22).
WLB_SSH_PORT=22

# User account on the Windows side that owns the SSH key's authorized_keys.
WLB_SSH_USER=<your-windows-user>

# Path to the private key (controller side). Use a dedicated key for wlb.
WLB_SSH_KEY=~/.ssh/wlb_ed25519

# Known-hosts file (optional). Default: ~/.ssh/known_hosts.
# WLB_SSH_KNOWN_HOSTS=~/.ssh/known_hosts

# ─── Transport selection ──────────────────────────────────────────
# Override the active transport without touching the profile. Values:
# ssh | local | http | hybrid. Default: ssh.
# WLB_TRANSPORT=ssh

# ─── Workspace location ───────────────────────────────────────────
# Where wlb writes captured stdout, tool logs, pulled files. Default:
# <repo>/workspace if it exists, else ~/.wlb-workspace.
# WLB_WORKSPACE=~/.wlb-workspace

# ─── SMB / Samba bridge ───────────────────────────────────────────
# Optional path translation table. Format: <linux-mount>=<windows-path>.
# Multiple entries separated by ';'.
#
# When set, `wlb fs push|pull` accepts EITHER form of path and translates
# transparently. If the Linux mount is actually present on this host,
# wlb skips SFTP and just copies on the Linux side — the Windows side
# sees the file through the share.
#
# Inspect what's loaded with: wlb fs maps
# WLB_SMB_MAPS=/mnt/win-share=C:\share;/mnt/factory=D:\factory

# ─── Debug ────────────────────────────────────────────────────────
# WLB_DEBUG=1
